# ──────────────────────────────────────────────────────
# INVITELY — Variables para desarrollo local con Docker
# Copia este archivo a .env.local y a .env
# ──────────────────────────────────────────────────────

# Base de datos local (Docker)
# Ajusta el password si tu contenedor tiene uno diferente
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/invitely"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/invitely"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="invitely-dev-secret-cambia-esto-en-produccion"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Invitely"

# ── Servicios opcionales para desarrollo local ──────────
# Deja vacíos los que no tengas — la app funciona sin ellos
# Verás mensajes "[DEV MODE]" en la consola en su lugar

# Google OAuth (opcional en local)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe (opcional en local — pagos no funcionarán)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Resend — emails (opcional, en DEV modo solo loguea en consola)
RESEND_API_KEY=""

# Cloudinary — imágenes (opcional, upload dará error sin esto)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Redis / Upstash (opcional, app funciona sin caché)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Anthropic — IA (opcional, devuelve textos de ejemplo sin esto)
ANTHROPIC_API_KEY=""

# Mapbox (opcional, mapa no aparece sin esto)
NEXT_PUBLIC_MAPBOX_TOKEN=""
