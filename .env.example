# ─────────────────────────────────────────────────────
# INVITELY — Variables de entorno
# Copia a .env.local para desarrollo local
# En Vercel: Settings → Environment Variables
# ─────────────────────────────────────────────────────

# ── BASE DE DATOS ─────────────────────────────────────
# Neon (recomendado): https://neon.tech
# Usa el connection string "pooled" para DATABASE_URL
# y "direct" para DIRECT_URL (migraciones Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/invitely?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/invitely"

# ── AUTENTICACIÓN ─────────────────────────────────────
NEXTAUTH_URL="https://tudominio.com"
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="genera-un-secret-con-openssl-rand-base64-32"

# Google OAuth (opcional — activa el botón "Continuar con Google")
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── PAGOS — STRIPE ────────────────────────────────────
# Usa sk_test_ / pk_test_ en desarrollo, sk_live_ / pk_live_ en producción
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── EMAILS — RESEND ───────────────────────────────────
# https://resend.com — verifica tu dominio en producción
RESEND_API_KEY="re_..."
# Dirección de envío (debe estar en un dominio verificado en Resend)
EMAIL_FROM="Invira <hola@tudominio.com>"

# ── IMÁGENES — CLOUDINARY ─────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── CACHÉ — UPSTASH REDIS ─────────────────────────────
# https://upstash.com — plan gratuito suficiente para empezar
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── IA — ANTHROPIC ────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── CRON — RECORDATORIOS AUTOMÁTICOS ─────────────────
# Genera con: openssl rand -base64 32
# Configura en Vercel → Settings → Cron Jobs
CRON_SECRET="genera-un-secret-con-openssl-rand-base64-32"

# ── APP ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://tudominio.com"
